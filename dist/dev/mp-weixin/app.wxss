page {
  background-color: #f5f5f5;
  color: #333333;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Microsoft YaHei", sans-serif;
  line-height: 1.6;
}
.container {
  padding: 24rpx;
}
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.btn-primary {
  background-color: #1a6b3c;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.btn-primary::after {
  border: none;
}
.btn-secondary {
  background-color: #ff6b00;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.btn-secondary::after {
  border: none;
}
.text-center {
  text-align: center;
}
.text-primary {
  color: #1a6b3c;
}
.text-secondary {
  color: #666666;
}
.text-light {
  color: #999999;
}
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}
.flex-1 {
  flex: 1;
}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}