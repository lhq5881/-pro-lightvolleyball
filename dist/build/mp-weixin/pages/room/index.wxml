<view class="room-page data-v-8281c3e7"><view wx:if="{{a}}" class="type-section data-v-8281c3e7"><text class="type-label data-v-8281c3e7">选择比赛类型</text><view class="type-options data-v-8281c3e7"><view class="type-option qipai-option data-v-8281c3e7" bindtap="{{b}}"><text class="type-name data-v-8281c3e7">气排球</text><text class="type-desc data-v-8281c3e7">5人制</text></view><view class="type-option indoor-option data-v-8281c3e7" bindtap="{{c}}"><text class="type-name data-v-8281c3e7">室内排球</text><text class="type-desc data-v-8281c3e7">6人制</text></view><view class="type-option beach-option data-v-8281c3e7" bindtap="{{d}}"><text class="type-name data-v-8281c3e7">沙滩排球</text><text class="type-desc data-v-8281c3e7">2人制</text></view></view></view><view wx:elif="{{e}}" class="mode-section data-v-8281c3e7"><view wx:if="{{f}}" class="loading data-v-8281c3e7"><text class="loading-text data-v-8281c3e7">正在创建房间...</text></view><view wx:elif="{{g}}" class="waiting data-v-8281c3e7"><text class="label data-v-8281c3e7">房间码</text><view class="room-code-display data-v-8281c3e7"><text wx:for="{{h}}" wx:for-item="char" wx:key="b" class="code-char data-v-8281c3e7">{{char.a}}</text></view><text class="hint data-v-8281c3e7">将房间码告诉对方，等待加入</text><view class="waiting-indicator data-v-8281c3e7"><view class="dot dot1 data-v-8281c3e7"></view><view class="dot dot2 data-v-8281c3e7"></view><view class="dot dot3 data-v-8281c3e7"></view></view></view><view wx:elif="{{i}}" class="connected data-v-8281c3e7"><text class="success-text data-v-8281c3e7">对方已加入！</text><text class="hint data-v-8281c3e7">即将进入比赛设置...</text></view><view wx:elif="{{j}}" class="error data-v-8281c3e7"><text class="error-text data-v-8281c3e7">{{k}}</text><button class="retry-btn data-v-8281c3e7" bindtap="{{l}}">重试</button></view></view><view wx:if="{{m}}" class="mode-section data-v-8281c3e7"><view wx:if="{{n}}" class="join-form data-v-8281c3e7"><text class="label data-v-8281c3e7">输入房间码</text><view class="code-input-row data-v-8281c3e7"><i